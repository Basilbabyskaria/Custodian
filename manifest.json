{
    "name": "Custodian",
    "version": "1.0.0",
    "manifest_version": 3 ,
    "content_scripts":[
        {
            "matches":
            [
               "*://*.youtube.com/*",
               "*://*.facebook.com/*",
               "*://*.instagram.com/*",
               "*://*.twitter.com/*"
            ],
          "js":["content.js"]
        }
    ],
    "action":{
        "default_popup":"popup.html",
        "default_icon":"logo.png"
        
    },
    "permissions": [
        "activeTab",
        "storage",
        "http://localhost/*"
        
      ]


}